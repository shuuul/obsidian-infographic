{
	"name": "obsidian-infographic",
	"version": "0.1.9",
	"description": "Render AntV Infographic visualizations from fenced code blocks in Obsidian",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [],
	"license": "Apache-2.0",
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@eslint/json": "2.0.0",
		"@types/node": "^26.0.1",
		"esbuild": "0.28.1",
		"eslint-plugin-obsidianmd": "0.3.0",
		"globals": "17.7.0",
		"jiti": "2.7.0",
		"tslib": "2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "8.62.0"
	},
	"dependencies": {
		"@antv/infographic": "^0.2.19",
		"obsidian": "^1.13.1"
	}
}
